    {
      "name": "Sort Products Ascending (price)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response contains items sorted ascending by price\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(Array.isArray(jsonData.items)).to.be.true;",
              "    for (var i = 1; i < jsonData.items.length; i++) {",
              "        pm.expect(jsonData.items[i].price).to.be.at.least(jsonData.items[i-1].price);",
