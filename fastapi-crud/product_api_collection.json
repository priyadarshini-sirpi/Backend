  "item": [
    {
      "name": "Create Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 Created\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Response contains valid product ID\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.collectionVariables.set(\"product_id\", jsonData.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Wireless Mechanical Keyboard\",\n  \"description\": \"Compact 75% mechanical keyboard with RGB backlighting.\",\n  \"price\": 89.99,\n  \"in_stock\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/items",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "items"
          ]
        }
      }
    },
    {
      "name": "Get All Products",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response contains total, skip, limit, and items array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('total');",
              "    pm.expect(jsonData).to.have.property('skip');",
              "    pm.expect(jsonData).to.have.property('limit');",
              "    pm.expect(Array.isArray(jsonData.items)).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/items?skip=0&limit=10",
          "host": [
            "{{base_url}}"
